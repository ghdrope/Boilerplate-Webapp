{
  "name": "frontend",
  "version": "0.0.4-SNAPSHOT",
  "private": true,
  "type": "module",
  "dependencies": {
    "@testing-library/dom": "^10.4.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.2.0",
    "@types/react": "^19.1.9",
    "@types/react-dom": "^19.1.7",
    "form-data": "4.0.4",
    "nth-check": "2.1.1",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "typescript": "5.9.2",
    "web-vitals": "^5.1.0"
  },
  "scripts": {
    "ci_workflow_test_push": "npm-run-all lint type-check format:check lint:css build test:unit",
    "ci_workflow_test_pr": "npm-run-all test:integration",
    "sast_workflow_test_pr": "npm-run-all lint type-check sast:audit sast:trivy-fs sast:trivy-dockerfile",
    "fix": "npm-run-all lint:fix format lint:css:fix",
    "app-dev": "docker-compose -f ../compose/docker-compose-dev.yaml up --build",
    "app-dev-down": "docker-compose -f ../compose/docker-compose-dev.yaml down",
    "backend": "make -C ../backend dev",
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "jest --coverage",
    "test:unit": "jest --testPathIgnorePatterns=integration --coverage",
    "test:integration": "jest --testPathPatterns=\\.integration\\.test\\.tsx$ --coverage=false --silent",
    "lint": "eslint 'src/**/*.{ts,tsx,js,jsx}'",
    "lint:fix": "eslint 'src/**/*.{ts,tsx,js,jsx}' --fix",
    "lint:css": "stylelint \"**/*.css\"",
    "lint:css:fix": "stylelint \"**/*.css\" --fix",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "type-check": "tsc --noEmit",
    "sast:audit": "yarn audit --groups dependencies --level high",
    "sast:trivy-fs": "trivy fs --severity HIGH,CRITICAL --scanners vuln,secret .",
    "sast:trivy-dockerfile": "trivy config --severity HIGH,CRITICAL ../docker/frontend.dockerfile",
    "clean": "rm -rf node_modules dist coverage package-lock.json"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "devDependencies": {
    "@babel/core": "^7.11.0",
    "@babel/plugin-syntax-flow": "^7.27.1",
    "@babel/plugin-transform-react-jsx": "^7.27.1",
    "@eslint/js": "^9.31.0",
    "@testing-library/jest-dom": "^6.6.4",
    "@testing-library/react": "^16.3.0",
    "@types/jest": "^30.0.0",
    "@typescript-eslint/eslint-plugin": "^8.38.0",
    "@typescript-eslint/parser": "^8.38.0",
    "@vitejs/plugin-react": "^5.0.0",
    "babel-jest": "^30.0.4",
    "eslint": "9.33.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-config-react-app": "^7.0.1",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "jest": "^30.0.4",
    "jest-environment-jsdom": "^30.0.5",
    "npm-run-all": "^4.1.5",
    "prettier": "^3.6.2",
    "stylelint": "^16.22.0",
    "stylelint-config-standard": "^39.0.0",
    "stylelint-order": "^7.0.0",
    "ts-jest": "^29.4.0",
    "ts-node": "^10.9.2",
    "vite": "^7.0.4"
  },
  "resolutions": {
    "eslint": "9.33.0"
  }
}
