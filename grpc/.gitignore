# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# Go build output
/bin/
*.exe
*.exe~
*.dll
*.so
*.dylib
*.test
*.out

# Go module files we don’t want generated here
vendor/

# Code generated by protoc
!gen/
!gen/proto/

# IDEs
.vscode/
.idea/

# OS metadata
.DS_Store
Thumbs.db

# Logs / temp
*.log
*.tmp
*.swp

# Local env
.env
*.local

# Go coverage output
*.out
*.coverprofile

# Go vulnerability check output
govulncheck-report.json